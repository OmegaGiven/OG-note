{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Read-only access to the sway-toolkit's shared theme file, for the Follow-system-theme option.",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$HOME/.config/sway-power/config.json" }]
    }
  ]
}
