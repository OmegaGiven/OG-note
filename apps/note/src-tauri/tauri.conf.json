{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OG Note",
  "version": "0.1.0",
  "identifier": "com.omegagiven.ognote",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OG Notes",
        "width": 980,
        "height": 720,
        "minWidth": 320,
        "minHeight": 520
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
