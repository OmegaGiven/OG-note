{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OG Note",
  "version": "0.2.2",
  "identifier": "com.omegagiven.ognote",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OG Note",
        "width": 980,
        "height": 720,
        "minWidth": 320,
        "minHeight": 520
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
